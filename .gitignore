app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Project-specific
# Model blobs are never committed (multi-GB, ML-engineer-owned, shipped
# via the asset/build pipeline) — broad pattern so a GGUF at any path,
# including the misplaced one at repo root, can't be accidentally added.
*.gguf
.env
train/

# TEMPORARY: ML-engineer artifact drops sitting at repo root (wrong
# location/name vs assets/model/gemma-4-E2B-it-Q4_K_M.gguf). The GGUF is
# permanently covered by *.gguf above; these two have no final home yet
# (inference_config.json has no consumer; system_prompt.txt is redundant
# with the tracked assets/prompts/witnessing_hard_moments.txt) — revisit
# before any release. See memory: project-root-artifacts-gitignored-temp.
inference_config.json
system_prompt.txt

# Android release-signing secrets — NEVER commit. The keystore itself
# lives outside the repo (~/.keystores/); key.properties holds its
# passwords. Losing both = the app can never be re-signed with the same
# identity (in-place updates break). The patterns below are defensive in
# case a keystore is ever placed inside the tree by mistake.
android/key.properties
*.jks
*.keystore
